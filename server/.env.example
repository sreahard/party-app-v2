# Twilio Credentials (get these from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Optional: frontend origin when the React app is on a different host than this API
# (e.g. https://myname.github.io). Same host as this server (e.g. Railway) does not need it.
CLIENT_ORIGIN=

PORT=3000

# Optional: absolute path to the SQLite file. On Railway, if you attach a Volume,
# Railway sets RAILWAY_VOLUME_MOUNT_PATH and this app writes rsvp.db there automatically.
# Set SQLITE_PATH only to override (e.g. SQLITE_PATH=/data/custom.db).
# SQLITE_PATH=
