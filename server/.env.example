# Twilio Credentials (get these from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Optional: frontend origin when the React app is on a different host than this API
# (e.g. https://myname.github.io). Same host as this server (e.g. Railway) does not need it.
CLIENT_ORIGIN=

PORT=3000

# Optional: absolute path to the SQLite file. Required on ephemeral hosts (Railway,
# Fly, etc.) if you attach a persistent volume — e.g. SQLITE_PATH=/data/rsvp.db
# SQLITE_PATH=
