# Twilio Credentials (get these from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# In production, set this to the URL of your deployed frontend
# so the server can send CORS headers (e.g. https://myname.github.io)
# Leave blank if serving the React build from the same Express server.
CLIENT_ORIGIN=

PORT=3000
